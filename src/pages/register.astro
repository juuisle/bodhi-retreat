---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ghi Danh | Khóa Phật Thất tại Bồ Đề Đạo Tràng">
    <section class="max-w-4xl py-16 space-y-10">
        <div>
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">Ghi danh</p>
            <h1 class="mb-6">Thông Tin Ghi Danh</h1>
            <p class="max-w-3xl text-lg leading-8 text-neutral-700">
                Kính mời quý Phật tử ghi danh tham dự khóa Phật Thất tại Bồ Đề Đạo Tràng. Quý vị cũng có thể liên hệ để tìm hiểu thêm về hành hương, lưu trú và
                các sắp xếp cần thiết tại địa phương.
            </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Liên hệ</h2>
                <p class="mb-3 text-neutral-700">
                    Email:
                    <a href="mailto:bodhi-retreat@web.de">bodhi-retreat@web.de</a>
                </p>
                <p class="text-neutral-700">
                    Website:
                    <a href="/">bodhi-retreat.info</a>
                </p>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Chi phí</h2>
                <p class="leading-8 text-neutral-700">
                    Hành giả tự túc vé máy bay, lưu trú, ăn uống, di chuyển và các chi phí cá nhân khác. Tuy nhiên, các tự viện tổ chức sẽ hoan hỷ hỗ trợ tư vấn
                    và phối hợp khi cần thiết.
                </p>
            </div>
        </div>

        <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
            <h2 class="mb-4">Cách ghi danh</h2>
            <p class="mb-5 leading-8 text-neutral-700">
                Quý vị vui lòng gửi email với họ tên, quốc gia cư trú và nhu cầu tham dự khóa tu hoặc hành hương 4 ngày tùy chọn. Ban tổ chức sẽ phản hồi với
                thông tin chi tiết.
            </p>

            <a
                href="mailto:bodhi-retreat@web.de?subject=Ghi%20danh%20Kh%C3%B3a%20Ph%E1%BA%ADt%20Th%E1%BA%A5t%20B%E1%BB%93%20%C4%90%E1%BB%81%20%C4%90%E1%BA%A1o%20Tr%C3%A0ng"
                class="btn btn-lg rounded-2xl"
            >
                Gửi email ghi danh
            </a>
        </div>
    </section>
</Layout>
