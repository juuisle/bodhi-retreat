

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Pilgrimage">
    <section class="mx-auto max-w-4xl px-6 py-16">
        <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 mb-6">Pilgrimage</h1>

        <p class="text-lg leading-8 text-neutral-700 mb-10">
            Participants may optionally join a 4-day guided pilgrimage before the retreat begins
            <strong>(December 24–27, 2026)</strong>.
        </p>

        <div class="space-y-10 text-neutral-800">
            <section>
                <h2 class="text-2xl font-semibold mb-4">Day 1 – December 24</h2>
                <ul class="list-disc pl-6 space-y-2 leading-7">
                    <li>Dungeshwari Cave Temples (site of ascetic practice)</li>
                    <li>Sujata Stupa</li>
                    <li>Mahabodhi Temple Complex</li>
                </ul>
            </section>

            <section>
                <h2 class="text-2xl font-semibold mb-4">Day 2 – December 25 (Rajgir &amp; Nalanda)</h2>
                <ul class="list-disc pl-6 space-y-2 leading-7">
                    <li>Early drive to Rajgir</li>
                    <li>Vulture Peak (Gridhrakuta Hill)</li>
                    <li>Nalanda University Ruins</li>
                </ul>
            </section>

            <section>
                <h2 class="text-2xl font-semibold mb-4">Day 3 – December 26 (Vaishali – Smriti Park – Varanasi)</h2>
                <ul class="list-disc pl-6 space-y-2 leading-7">
                    <li>Early drive to Vaishali</li>
                    <li>Vaishali (site of the Buddha’s last discourse and the first Bhikkhuni ordination)</li>
                    <li>Smriti Park</li>
                    <li>Drive to Varanasi</li>
                    <li>Overnight stay in Varanasi</li>
                </ul>
            </section>

            <section>
                <h2 class="text-2xl font-semibold mb-4">Day 4 – December 27 (Sarnath / Varanasi)</h2>
                <ul class="list-disc pl-6 space-y-2 leading-7">
                    <li>Sarnath</li>
                    <li>Dhamek Stupa (site of the First Sermon)</li>
                    <li>Optional short visit to the Ganges River</li>
                    <li>Drive back to Bodh Gaya</li>
                </ul>
            </section>
        </div>
    </section>
</Layout>