---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Register | 7-Day Phật Thất Retreat at Bodh Gaya">
    <section class="max-w-5xl py-16 space-y-10">
        <div>
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">Register</p>
            <h1 class="mb-6">Registration Information</h1>
            <p class="max-w-3xl text-lg leading-8 text-neutral-700">
                Please complete the form below to register for the 7-Day Phật Thất Retreat at Bodh Gaya. You may also contact us for more information about the
                optional pilgrimage, accommodation, and local arrangements.
            </p>
        </div>

        <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
            <h2 class="mb-4">Registration Notes</h2>
            <p class="leading-8 text-neutral-700">
                Please fill in the form below as completely as possible. The organizing team will follow up if additional details are needed regarding the
                retreat or the optional 4-day pilgrimage. You can also register via the link here: <a href="https://forms.gle/oLQ1SPgb9MVty8vL6"
                    >https://forms.gle/oLQ1SPgb9MVty8vL6</a
                >
            </p>
        </div>

        <div class="rounded-2xl border border-neutral-200 bg-white p-3 sm:p-4">
            <iframe
                src="https://docs.google.com/forms/d/e/1FAIpQLSfcC0DLipT0YwS78gFs_WO9XRUS6RkOPKqRMBVb6I56CNO4bg/viewform?embedded=true"
                width="100%"
                height="6687"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                class="w-full"
            >
                Loading…
            </iframe>
        </div>
    </section>
</Layout>
