---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Register | 7-Day Phật Thất Retreat at Bodh Gaya">
    <section class="max-w-4xl py-16 space-y-10">
        <div>
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">Register</p>
            <h1 class="mb-6">Registration Information</h1>
            <p class="max-w-3xl text-lg leading-8 text-neutral-700">
                We warmly invite you to register for the 7-Day Phật Thất Retreat at Bodh Gaya. You may also contact us for more information about the optional
                pilgrimage, accommodation, and local arrangements.
            </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Contact</h2>
                <p class="mb-3 text-neutral-700">
                    Email:
                    <a href="mailto:bodhi-retreat@web.de">bodhi-retreat@web.de</a>
                </p>
                <p class="text-neutral-700">
                    Website:
                    <a href="/en">bodhi-retreat.info</a>
                </p>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Costs</h2>
                <p class="leading-8 text-neutral-700">
                    Participants are responsible for their own flight tickets, accommodation, meals, transportation, and personal expenses. The organizing
                    monasteries will gladly assist with coordination and recommendations where needed.
                </p>
            </div>
        </div>

        <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
            <h2 class="mb-4">How to Register</h2>
            <p class="mb-5 leading-8 text-neutral-700">
                Please send an email with your full name, country of residence, and whether you wish to join only the retreat or also the optional 4-day
                pilgrimage. The organizing team will follow up with further details.
            </p>

            <a href="mailto:bodhi-retreat@web.de?subject=Registration%20for%20Bodh%20Gaya%20Retreat" class="btn btn-lg rounded-2xl">
                Send Registration Email
            </a>
        </div>
    </section>
</Layout>
