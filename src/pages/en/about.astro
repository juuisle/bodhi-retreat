---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="About | 7-Day Phật Thất Retreat at Bodh Gaya">
    <section class="max-w-4xl py-16 space-y-10">
        <div>
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">About</p>
            <h1 class="mb-6">7-Day Phật Thất Retreat at Bodh Gaya</h1>
            <p class="max-w-3xl text-lg leading-8 text-neutral-700">
                This retreat will take place in Bodh Gaya, India, from
                <strong>December 28, 2026 to January 3, 2027</strong>, offering a precious opportunity to return to the sacred land of the Buddha for
                pilgrimage, spiritual practice, and the nourishment of inner peace.
            </p>

            <div id="image-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4">
                <button
                    id="image-modal-close"
                    type="button"
                    class="absolute right-4 top-4 rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-neutral-900"
                    aria-label="Close image"
                >
                    Close
                </button>
                <img id="image-modal-img" src="" alt="" class="max-h-[90vh] max-w-[95vw] rounded-2xl object-contain" />
            </div>
        </div>

        <a href="/images/khoatu/tuongphattaithap.jpg" class="popup-image block overflow-hidden rounded-3xl">
            <img
                src="/images/khoatu/tuongphattaithap.jpg"
                alt="Buddha statue at the temple"
                class="h-full max-h-[420px] w-full object-cover transition hover:opacity-95"
            />
        </a>

        <div class="grid gap-6">
            <div class="rounded-2xl border border-neutral-200 bg-white p-6 md:p-8">
                <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">Tentative Daily Schedule</p>
                <h2 class="mb-2">From December 28, 2026 to January 3, 2027</h2>
                <p class="mb-6 leading-8 text-neutral-700">Evenings are reserved for optional personal practice.</p>

                <div class="space-y-4 text-neutral-700">
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>05:00 – 07:00:</strong> Morning practice at Viên Giác Buddhist Learning Center – Bodh Gaya
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>07:30 – 09:00:</strong> Breakfast and rest
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>09:00 – 11:30:</strong> Practice at the Mahabodhi Temple
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>11:30 – 13:00:</strong> Lunch and rest
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>13:00 – 15:30:</strong> Practice at the Temple
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>15:30 – 17:00:</strong> Dharma talk
                    </div>
                    <div class="rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3">
                        <strong>17:00:</strong> End of the main daily program
                    </div>
                </div>

                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    <a href="/images/khoatu/tungkinhsangtaiviengiac.jpg" class="popup-image block">
                        <img
                            src="/images/khoatu/tungkinhsangtaiviengiac.jpg"
                            alt="Morning chanting at Viên Giác"
                            class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95"
                        />
                    </a>
                    <a href="/images/khoatu/suongkhoatu.jpeg" class="popup-image block">
                        <img
                            src="/images/khoatu/suongkhoatu.jpeg"
                            alt="Mahabodhi Temple"
                            class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95"
                        />
                    </a>
                    <a href="/images/khoatu/phaphoi.jpg" class="popup-image block">
                        <img src="/images/khoatu/phaphoi.jpg" alt="Dharma gathering" class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95" />
                    </a>
                    <a href="/images/khoatu/thapgiacngo2.jpg" class="popup-image block">
                        <img
                            src="/images/khoatu/thapgiacngo2.jpg"
                            alt="Buddha statue at the temple"
                            class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95"
                        />
                    </a>
                </div>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Returning to the Source of Buddhism</h2>
                <p class="leading-8 text-neutral-700">
                    More than 2,500 years ago, beneath the sacred Bodhi Tree at Bodh Gaya, the Blessed One attained unsurpassed perfect enlightenment, opening
                    the path of awakening and liberation for all beings. Returning to this sacred site is not merely a pilgrimage, but also a precious
                    opportunity for each practitioner to quiet the mind, reconnect deeply with the roots of Buddhism, and renew a steadfast faith in the Triple
                    Gem.
                </p>
                <p class="mt-4 leading-8 text-neutral-700">
                    In the serene atmosphere of the Buddha’s land, the community has the chance to slow down, set aside the burdens of daily life, and practice
                    mindfulness, chanting, meditation, and Dharma listening together in a spirit of harmony and awareness. It is also an opportunity to nourish
                    the bodhi mind, cultivate the seeds of peace and joy, and remember one’s original aspiration on the path of returning to oneself.
                </p>
                <a href="/images/khoatu/bodedaotrang.jpg" class="popup-image block">
                    <img src="/images/khoatu/bodedaotrang.jpg" alt="Bodh Gaya" class="mt-6 h-96 w-full rounded-2xl object-cover transition hover:opacity-95" />
                </a>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Practice Orientation</h2>
                <p class="leading-8 text-neutral-700">
                    The retreat follows the principle of <strong>integrated Chan and Pure Land practice</strong>, bringing together the contemplative spirit of
                    meditation and the deep faith of the Pure Land tradition. It is suitable both for practitioners devoted to Chan and for those who focus on
                    Buddha-recitation. In the peaceful environment of the Buddha’s land, participants will have the opportunity to nourish body and mind through
                    steady practice under the guidance of the Sangha.
                </p>
                <p class="mt-4 leading-8 text-neutral-700">
                    Those inclined toward Chan will learn and practice with monastics experienced in meditation guidance. Those devoted to Pure Land practice
                    will engage in Buddha-recitation, chanting, contemplation, and the cultivation of faith and vow, so that body and mind may rest in the
                    compassionate light of the Buddhas. These two dimensions of practice are not separate, but mutually supportive. As the patriarchs have
                    taught:
                </p>
                <p class="mt-4 leading-8 text-neutral-700">
                    “With Chan and with Pure Land,<br />
                    one is like a tiger with horns.<br />
                    In this life, a teacher of humans and devas;<br />
                    in future lives, a Buddha or a Patriarch.”
                </p>
                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    <a href="/images/khoatu/hanhgioihanhdinh.jpg" class="popup-image block">
                        <img
                            src="/images/khoatu/hanhgioihanhdinh.jpg"
                            alt="Practice of discipline and meditation"
                            class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95"
                        />
                    </a>
                    <a href="/images/khoatu/tangdoan.jpg" class="popup-image block">
                        <img
                            src="/images/khoatu/tangdoan.jpg"
                            alt="Sangha guiding the retreat"
                            class="h-72 w-full rounded-2xl object-cover transition hover:opacity-95"
                        />
                    </a>
                </div>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Language</h2>
                <p class="leading-8 text-neutral-700">
                    This retreat is especially open to both Vietnamese participants and international Buddhists. Therefore, the program will be conducted in two
                    languages throughout: <strong>Vietnamese</strong> and <strong>English</strong>. This offers a precious opportunity for practitioners from
                    many countries and cultural backgrounds to gather and practice together in a spirit of harmony, mutual respect, and shared support on the
                    path of the Dharma.
                </p>
                <p class="mt-4 leading-8 text-neutral-700">
                    During Dharma talks, participants will be divided into two groups according to language: one group will attend teachings in Vietnamese at
                    the
                    <strong>Viên Giác Buddhist Learning Center</strong>, and the other will attend teachings in English at the <strong
                        >Mahabodhi Temple, Bodh Gaya</strong
                    >. The monastic teachers are deeply grounded in the Dharma and capable of communicating it clearly and meaningfully across different
                    languages.
                </p>
                <a href="/images/khoatu/hinhsuphu.jpg" class="popup-image block">
                    <img
                        src="/images/khoatu/hinhsuphu.jpg"
                        alt="Monastic teachers"
                        class="mt-6 h-96 w-full rounded-2xl object-cover transition hover:opacity-95"
                    />
                </a>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Accommodation in India</h2>
                <p class="leading-8 text-neutral-700">
                    Participants are expected to <strong>cover all of their own expenses</strong>, including airfare, accommodation, meals, transportation, and
                    personal costs. The organizing monasteries will, however, help provide essential information, accommodation guidance, and local coordination
                    when needed.
                </p>
                <p class="mt-4 leading-8 text-neutral-700">
                    For lodging, the organizing team will prepare a list of hotels and may assist with booking rooms; however, participants are responsible for
                    <strong>checking in themselves</strong>, <strong>paying for their rooms</strong>, <strong>applying for their own visas</strong>, and
                    <strong>purchasing their own flight tickets</strong>. The organizers will not collect or manage accommodation payments on behalf of
                    participants.
                </p>
            </div>

            <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
                <h2 class="mb-4">Optional 4-Day Pilgrimage</h2>
                <a href="/images/khoatu/thapgiacngo4.jpg" class="popup-image block">
                    <img
                        src="/images/khoatu/thapgiacngo4.jpg"
                        alt="Mahabodhi Temple"
                        class="mb-6 h-96 w-full rounded-2xl object-cover transition hover:opacity-95"
                    />
                </a>
                <p class="leading-8 text-neutral-700">
                    Before the retreat begins, participants may join an optional pilgrimage from <strong>December 24 to December 27, 2026</strong>, visiting
                    sacred sites such as Dungeshwari Cave, Sujata Stupa, Rajgir, Vulture Peak, Nalanda, Vaishali, Sarnath, and other holy places. Please see
                    more details
                    <a href="/en/pilgrimage" class="font-medium text-neutral-900 underline underline-offset-4">here</a>.
                </p>
            </div>
        </div>

        <div class="pt-2">
            <a href="/en/register" class="btn btn-lg rounded-2xl">Register</a>
        </div>
    </section>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('image-modal');
        const modalImg = document.getElementById('image-modal-img');
        const closeBtn = document.getElementById('image-modal-close');
        const triggers = document.querySelectorAll('.popup-image');

        if (!modal || !modalImg || !closeBtn || triggers.length === 0) return;

        const openModal = (src, alt) => {
            modalImg.src = src;
            modalImg.alt = alt || '';
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        };

        const closeModal = () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            modalImg.src = '';
            modalImg.alt = '';
            document.body.classList.remove('overflow-hidden');
        };

        triggers.forEach((trigger) => {
            trigger.addEventListener('click', (event) => {
                event.preventDefault();
                const img = trigger.querySelector('img');
                openModal(trigger.getAttribute('href') || '', img?.getAttribute('alt') || '');
            });
        });

        closeBtn.addEventListener('click', closeModal);

        modal.addEventListener('click', (event) => {
            if (event.target === modal) closeModal();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
                closeModal();
            }
        });
    });
</script>
