---
const path = Astro.url.pathname;
const isEn = path.startsWith('/en');
const normalizedPath = path.replace(/\/+$/, '') || '/';
const isHome = normalizedPath === '/' || normalizedPath === '/en';
const homeLogos = [
    { src: '/images/viengiac-logo.jpg', alt: 'Viên Giác' },
    { src: '/images/voluongtho-logo.jpg', alt: 'Vô Lượng Thọ' },
    { src: '/images/lientam-logo.png', alt: 'Liên Tâm' },
    { src: '/images/vienlac-logo.jpg', alt: 'Viên Lạc' }
];
---

<header class="border-b border-neutral-200 py-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center justify-between md:block">
            <a href={isEn ? '/en' : '/'} class="no-underline text-neutral-900">
                {
                    isHome ? (
                        <div class="flex items-center gap-1.5">
                            {
                                homeLogos.map((logo, index) => (
                                    <>
                                        <img
                                            src={logo.src}
                                            alt={logo.alt}
                                            class="h-9 w-9 rounded-full border border-neutral-200 object-cover bg-white"
                                        />
                                        {index < homeLogos.length - 1 && (
                                            <span class="text-sm font-medium text-neutral-400">+</span>
                                        )}
                                    </>
                                ))
                            }
                        </div>
                    ) : (
                        <span class="text-xl font-semibold">{isEn ? '< Go home' : '< Đi về nhà'}</span>
                    )
                }
            </a>

            <a
                href={isEn ? '/' : '/en'}
                class="inline-flex items-center rounded-full border border-neutral-300 bg-neutral-100 px-4 py-2 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-400 hover:bg-neutral-200 md:hidden"
            >
                {isEn ? 'Tiếng Việt' : 'English'}
            </a>
        </div>

        <nav class="flex flex-wrap items-center gap-5 text-sm sm:text-base">
            {
                isEn ? (
                    <>
                        <a href="/en/about" class="no-underline text-neutral-700 hover:text-neutral-900">
                            About
                        </a>
                        <a href="/en/pilgrimage" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Pilgrimage
                        </a>
                        <a href="/en/teachers" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Teachers
                        </a>
                        <a href="/en/register" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Register
                        </a>
                        <a
                            href="/"
                            class="hidden md:inline-flex items-center rounded-full border border-neutral-300 bg-neutral-100 px-4 py-2 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-400 hover:bg-neutral-200"
                        >
                            Tiếng Việt
                        </a>
                    </>
                ) : (
                    <>
                        <a href="/about" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Giới thiệu
                        </a>
                        <a href="/pilgrimage" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Hành hương
                        </a>
                        <a href="/teachers" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Giảng sư
                        </a>
                        <a href="/register" class="no-underline text-neutral-700 hover:text-neutral-900">
                            Ghi danh
                        </a>
                        <a
                            href="/en"
                            class="hidden md:inline-flex items-center rounded-full border border-neutral-300 bg-neutral-100 px-4 py-2 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-400 hover:bg-neutral-200"
                        >
                            English
                        </a>
                    </>
                )
            }
        </nav>
    </div>
</header>
